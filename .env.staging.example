# =============================================================================
# eclat — Staging Environment Variables
# These live in AWS Secrets Manager at /eclat/staging/*
# Never store actual values in this file — it's a reference template only.
# =============================================================================

NEXTAUTH_URL=https://staging.eclat.in
NEXTAUTH_SECRET=<from Secrets Manager: /eclat/staging/nextauth-secret>
NODE_ENV=staging

DATABASE_URL=<from Secrets Manager: /eclat/staging/database-url>

GOOGLE_CLIENT_ID=<from Secrets Manager: /eclat/staging/google-client-id>
GOOGLE_CLIENT_SECRET=<from Secrets Manager: /eclat/staging/google-client-secret>

# Stripe TEST keys for staging
STRIPE_SECRET_KEY=sk_test_<from Secrets Manager: /eclat/staging/stripe-secret-key>
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_<from Secrets Manager: /eclat/staging/stripe-publishable-key>
STRIPE_WEBHOOK_SECRET=<from Secrets Manager: /eclat/staging/stripe-webhook-secret>

RAZORPAY_KEY_ID=rzp_test_<from Secrets Manager: /eclat/staging/razorpay-key-id>
RAZORPAY_KEY_SECRET=<from Secrets Manager: /eclat/staging/razorpay-key-secret>
RAZORPAY_WEBHOOK_SECRET=<from Secrets Manager: /eclat/staging/razorpay-webhook-secret>

PUSHER_APP_ID=<from Secrets Manager: /eclat/staging/pusher-app-id>
PUSHER_KEY=<from Secrets Manager: /eclat/staging/pusher-key>
NEXT_PUBLIC_PUSHER_KEY=<from Secrets Manager: /eclat/staging/pusher-key>
PUSHER_SECRET=<from Secrets Manager: /eclat/staging/pusher-secret>
PUSHER_CLUSTER=ap2
NEXT_PUBLIC_PUSHER_CLUSTER=ap2

DAILY_API_KEY=<from Secrets Manager: /eclat/staging/daily-api-key>
DAILY_DOMAIN=eclat-staging.daily.co

UPSTASH_REDIS_REST_URL=<from Secrets Manager: /eclat/staging/upstash-redis-url>
UPSTASH_REDIS_REST_TOKEN=<from Secrets Manager: /eclat/staging/upstash-redis-token>

RESEND_API_KEY=<from Secrets Manager: /eclat/staging/resend-api-key>
EMAIL_FROM=noreply@eclat.in

AWS_REGION=ap-southeast-1
AWS_S3_BUCKET_PROFILES=eclat-profiles-staging-<account-id>
AWS_S3_BUCKET_VERIFICATION=eclat-verification-staging-<account-id>
AWS_KMS_KEY_ARN=<from Terraform output: kms_key_arn>

SENTRY_DSN=<from Secrets Manager: /eclat/staging/sentry-dsn>
NEXT_PUBLIC_SENTRY_DSN=<from Secrets Manager: /eclat/staging/sentry-dsn>
