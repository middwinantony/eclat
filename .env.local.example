# =============================================================================
# eclat — Local Development Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
# The URL where the app runs locally
NEXTAUTH_URL=http://localhost:3000

# Generate with: openssl rand -base64 32
# Used to sign JWT tokens — must be secret and at least 32 chars
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# For local dev: run `docker run -e POSTGRES_PASSWORD=password -p 5432:5432 postgres:15`
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/eclat_dev

# ── Google OAuth ──────────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add authorized redirect URI: http://localhost:3000/api/auth/callback/google
# Looks like: 123456789-abcdefghij.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Looks like: GOCSPX-abcdefghijklmnopqrstuvwxyz
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# ── Stripe (International Payments) ──────────────────────────────────────────
# 1. Go to https://dashboard.stripe.com/test/apikeys
# 2. Use TEST keys for development (sk_test_... and pk_test_...)
# Looks like: sk_test_51...
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# Looks like: pk_test_51...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# For local webhook testing: stripe listen --forward-to localhost:3000/api/webhooks/stripe
# Looks like: whsec_...
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ── Razorpay (India Payments) ─────────────────────────────────────────────────
# 1. Go to https://dashboard.razorpay.com/app/website-app-settings/api-keys
# 2. Use TEST mode for development
# Looks like: rzp_test_...
RAZORPAY_KEY_ID=rzp_test_your-key-id

# Looks like: a random alphanumeric string
RAZORPAY_KEY_SECRET=your-razorpay-secret

# Your webhook secret from Razorpay dashboard
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ── Pusher (Real-time Messaging) ──────────────────────────────────────────────
# 1. Sign up at https://pusher.com
# 2. Create an app — choose ap2 (Singapore) as cluster
# Looks like: 1234567
PUSHER_APP_ID=your-pusher-app-id

# Looks like: abcdef1234567890
PUSHER_KEY=your-pusher-key
NEXT_PUBLIC_PUSHER_KEY=your-pusher-key

# Looks like: abcdef1234567890abcdef1234567890
PUSHER_SECRET=your-pusher-secret

# Looks like: ap2
PUSHER_CLUSTER=ap2
NEXT_PUBLIC_PUSHER_CLUSTER=ap2

# ── Daily.co (Video Calls) ────────────────────────────────────────────────────
# 1. Sign up at https://www.daily.co
# 2. Go to Developers → API keys
# Looks like: abcdefghijklmnopqrstuvwxyz1234567890
DAILY_API_KEY=your-daily-api-key

# Your Daily.co subdomain (e.g. "eclat" → eclat.daily.co)
DAILY_DOMAIN=your-domain.daily.co

# ── Upstash Redis (Rate Limiting) ─────────────────────────────────────────────
# 1. Sign up at https://console.upstash.com
# 2. Create a Redis database — choose ap-southeast-1
# 3. Copy REST URL and REST Token from the dashboard
# Looks like: https://xxx-xxx.upstash.io
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io

# Looks like: AXxxxxxxxxxxxxxxxx
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Email (Resend for dev, SES for prod) ──────────────────────────────────────
# 1. Sign up at https://resend.com
# 2. Get API key from https://resend.com/api-keys
# Looks like: re_xxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_API_KEY=re_your-resend-api-key

# The from address for emails — use onboarding@resend.dev for testing
EMAIL_FROM=onboarding@resend.dev

# ── AWS (for S3 photo uploads in dev) ────────────────────────────────────────
# Only needed if testing file uploads locally
# Use an IAM user with S3 and KMS permissions
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET_PROFILES=eclat-profiles-dev-your-account-id
AWS_S3_BUCKET_VERIFICATION=eclat-verification-dev-your-account-id
AWS_KMS_KEY_ARN=arn:aws:kms:ap-southeast-1:YOUR_ACCOUNT_ID:key/your-key-id

# ── Error Tracking ────────────────────────────────────────────────────────────
# 1. Sign up at https://sentry.io
# 2. Create a Next.js project
# 3. Copy the DSN from Project Settings → Client Keys
# Looks like: https://abc123@o123456.ingest.sentry.io/1234567
SENTRY_DSN=https://your-dsn@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@o0.ingest.sentry.io/0
