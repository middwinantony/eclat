# =============================================================================
# eclat — Production Environment Variables
# These live in AWS Secrets Manager at /eclat/prod/*
# NEVER store actual production values in this file.
# =============================================================================

NEXTAUTH_URL=https://eclat.in
NEXTAUTH_SECRET=<from Secrets Manager: /eclat/prod/nextauth-secret>
NODE_ENV=production

DATABASE_URL=<from Secrets Manager: /eclat/prod/database-url>

GOOGLE_CLIENT_ID=<from Secrets Manager: /eclat/prod/google-client-id>
GOOGLE_CLIENT_SECRET=<from Secrets Manager: /eclat/prod/google-client-secret>

# Stripe LIVE keys for production
STRIPE_SECRET_KEY=sk_live_<from Secrets Manager: /eclat/prod/stripe-secret-key>
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_<from Secrets Manager: /eclat/prod/stripe-publishable-key>
STRIPE_WEBHOOK_SECRET=<from Secrets Manager: /eclat/prod/stripe-webhook-secret>

RAZORPAY_KEY_ID=rzp_live_<from Secrets Manager: /eclat/prod/razorpay-key-id>
RAZORPAY_KEY_SECRET=<from Secrets Manager: /eclat/prod/razorpay-key-secret>
RAZORPAY_WEBHOOK_SECRET=<from Secrets Manager: /eclat/prod/razorpay-webhook-secret>

PUSHER_APP_ID=<from Secrets Manager: /eclat/prod/pusher-app-id>
PUSHER_KEY=<from Secrets Manager: /eclat/prod/pusher-key>
NEXT_PUBLIC_PUSHER_KEY=<from Secrets Manager: /eclat/prod/pusher-key>
PUSHER_SECRET=<from Secrets Manager: /eclat/prod/pusher-secret>
PUSHER_CLUSTER=ap2
NEXT_PUBLIC_PUSHER_CLUSTER=ap2

DAILY_API_KEY=<from Secrets Manager: /eclat/prod/daily-api-key>
DAILY_DOMAIN=eclat.daily.co

UPSTASH_REDIS_REST_URL=<from Secrets Manager: /eclat/prod/upstash-redis-url>
UPSTASH_REDIS_REST_TOKEN=<from Secrets Manager: /eclat/prod/upstash-redis-token>

EMAIL_FROM=noreply@eclat.in
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET_PROFILES=eclat-profiles-prod-<account-id>
AWS_S3_BUCKET_VERIFICATION=eclat-verification-prod-<account-id>
AWS_KMS_KEY_ARN=<from Terraform output: kms_key_arn>

SENTRY_DSN=<from Secrets Manager: /eclat/prod/sentry-dsn>
NEXT_PUBLIC_SENTRY_DSN=<from Secrets Manager: /eclat/prod/sentry-dsn>
